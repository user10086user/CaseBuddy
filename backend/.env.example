# 后端环境变量示例
# 复制此文件为 .env 并填写实际值

# 后端服务端口
PORT=3001

# LLM API 配置（工作流引擎使用）
# 可替换为任意 OpenAI 兼容格式的 API
LLM_BASE_URL=https://chat.ecnu.edu.cn/open/api/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=ecnu-plus

# 可选：备用模型配置
# LLM_BASE_URL_BACKUP=https://api.deepseek.com
# LLM_API_KEY_BACKUP=your-backup-key
# LLM_MODEL_BACKUP=deepseek-chat
