      "encryptKey": "your-encrypt-key",
      "allowedUsers": []
    },
    "telegram": {
      "enabled": false,
      "botToken": "your-telegram-bot-token",
      "allowedUsers": []
    }
  },
  "llm": {
    "proxyUrl": "http://localhost:3001",
    "defaultModel": "ecnu-plus",
    "streamDelay": 500,
    "sessionTimeout": 300,
    "maxHistory": 20
  }
