{
  "gateways": {
    "wecom": {
      "enabled": false,
      "botId": "your-bot-id",
      "secret": "your-bot-secret",
      "welcomeMessage": "您好！我是 CaseBuddy MBA 案例分析助手，请直接发送您的问题。",
      "allowedUsers": []
    },
    "feishu": {
      "enabled": false,
      "appId": "your-feishu-app-id",
